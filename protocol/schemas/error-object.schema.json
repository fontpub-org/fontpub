{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fontpub.org/schemas/v1/error-object.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "details"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    }
  }
}
