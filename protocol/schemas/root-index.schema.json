{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fontpub.org/schemas/v1/root-index.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "packages"],
  "properties": {
    "schema_version": { "const": "1" },
    "generated_at": { "type": "string" },
    "packages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["latest_version", "latest_version_key", "latest_published_at"],
        "properties": {
          "latest_version": { "type": "string" },
          "latest_version_key": { "type": "string" },
          "latest_published_at": { "type": "string" }
        }
      }
    }
  }
}
