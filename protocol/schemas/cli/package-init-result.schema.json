{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fontpub.org/schemas/v1/cli/package-init-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "ok", "command", "data"],
  "properties": {
    "schema_version": { "const": "1" },
    "ok": { "const": true },
    "command": { "const": "package init" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "inferences", "conflicts", "unresolved_fields"],
      "properties": {
        "manifest": { "type": "object" },
        "inferences": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "value", "source"],
            "properties": {
              "field": { "type": "string" },
              "value": {},
              "source": { "enum": ["embedded_metadata", "filename_heuristic", "user_input"] }
            }
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "resolved", "candidates"],
            "properties": {
              "field": { "type": "string" },
              "resolved": { "type": "boolean" },
              "chosen_value": { "type": "string" },
              "candidates": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["value", "source"],
                  "properties": {
                    "value": { "type": "string" },
                    "source": { "enum": ["embedded_metadata", "filename_heuristic", "user_input"] }
                  }
                }
              }
            }
          }
        },
        "unresolved_fields": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
